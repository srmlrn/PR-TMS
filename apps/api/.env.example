# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001

# Auth
JWT_SECRET=change-me-in-production

# Storage: memory (default) or postgres
STORAGE_MODE=memory

# PostgreSQL (when STORAGE_MODE=postgres)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=tms
DATABASE_PASSWORD=tms_dev
DATABASE_NAME=tms_control
TENANT_DB_USER=tms
TENANT_DB_PASSWORD=tms_dev
DB_LOGGING=false

# Stripe (live card payments — omit for demo mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay (live INR payments — omit for demo mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
