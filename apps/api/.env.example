# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001

# Auth
JWT_SECRET=change-me-in-production

# Storage: memory (default) or postgres
STORAGE_MODE=memory

# PostgreSQL (when STORAGE_MODE=postgres)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=tms
DATABASE_PASSWORD=tms_dev
DATABASE_NAME=tms_control
TENANT_DB_USER=tms
TENANT_DB_PASSWORD=tms_dev
DB_LOGGING=false

# Stripe (live card + Apple Pay + Google Pay — omit keys for demo mode)
# Webhook endpoint: POST /api/v1/payments/webhooks/stripe
# Per-tenant keys are preferred (Admin → Payment Settings); env keys are memory-mode fallback only.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay (live INR + UPI QR — omit keys for demo mode)
# Webhook endpoint: POST /api/v1/payments/webhooks/razorpay
# Enable UPI + QR in Razorpay Dashboard test mode for live QR testing.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# PayPal (+ Venmo via JS SDK — omit keys for demo mode)
# Webhook endpoint: POST /api/v1/payments/webhooks/paypal
# Per-tenant keys are preferred (Admin → Payment Settings); env keys are memory-mode fallback only.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# QR / UPI demo (no Razorpay keys required)
# DEMO_UPI_VPA=your-temple@upi
DEMO_UPI_VPA=temple.demo@upi
# Public web URL encoded in non-INR demo QR codes
WEB_PAY_ORIGIN=http://localhost:3001

# Apple Pay domain file is configured on the web app (APPLE_PAY_DOMAIN_ASSOCIATION).
