# API connection
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_TENANT_ID=00000000-0000-0000-0000-000000000001

# Payment mode badge: "demo" (default) or "live"
NEXT_PUBLIC_PAYMENT_MODE=demo

# Live Stripe (card + Apple Pay + Google Pay via Payment Element)
# Publishable key is returned per session from tenant payment settings when live.
# Optional legacy fallback (prefer Admin → Payment Settings):
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Apple Pay domain verification (production HTTPS only)
# Paste full file contents from Stripe Dashboard → Settings → Payment methods → Apple Pay
# Served at /.well-known/apple-developer-merchantid-domain-association
APPLE_PAY_DOMAIN_ASSOCIATION=

# Live Razorpay (INR) — key id only; secret stays on API server
NEXT_PUBLIC_RAZORPAY_KEY_ID=
