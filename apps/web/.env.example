# API connection
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_TENANT_ID=00000000-0000-0000-0000-000000000001

# Payment mode badge: "demo" (default) or "live"
NEXT_PUBLIC_PAYMENT_MODE=demo

# Live Stripe (card) — publishable key only; secret key stays on API server
# Demo: use Stripe test publishable key pk_test_...
# Live: use Stripe live publishable key pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Live Razorpay (INR) — key id only; secret stays on API server
# Demo: use Razorpay test key_id rzp_test_...
# Live: use Razorpay live key_id rzp_live_...
NEXT_PUBLIC_RAZORPAY_KEY_ID=
