# Copy to .env and edit before: docker compose up -d --build

# --- Postgres ---
POSTGRES_USER=tms
POSTGRES_PASSWORD=change-this-postgres-password

# --- API ---
NODE_ENV=production
PORT=3000
STORAGE_MODE=postgres
JWT_SECRET=change-this-to-a-long-random-string
TENANT_DB_SYNC=true

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=tms
DATABASE_PASSWORD=change-this-postgres-password
DATABASE_NAME=tms_control
TENANT_DB_USER=tms
TENANT_DB_PASSWORD=change-this-postgres-password

# Public URLs (use https:// after DNS + Caddy certs)
CORS_ORIGIN=http://YOUR_VM_IP
WEB_PAY_ORIGIN=http://YOUR_VM_IP
DEMO_UPI_VPA=temple.demo@upi

# Stripe/Razorpay platform keys (optional — or configure per tenant in Admin UI)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# --- Web (baked into image at build time) ---
NEXT_PUBLIC_API_URL=http://YOUR_VM_IP/api/v1
NEXT_PUBLIC_PAYMENT_MODE=demo

# --- Caddy / domains (leave WEB_DOMAIN and API_DOMAIN empty for IP-only) ---
WEB_DOMAIN=
API_DOMAIN=
ACME_EMAIL=you@example.com

# When you have a domain, use e.g.:
# WEB_DOMAIN=demo.yourdomain.com
# API_DOMAIN=api.yourdomain.com
# CORS_ORIGIN=https://demo.yourdomain.com
# WEB_PAY_ORIGIN=https://demo.yourdomain.com
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
